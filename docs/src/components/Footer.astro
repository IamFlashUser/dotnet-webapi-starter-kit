					</a>
					<a href="https://twitter.com/iammukeshm" target="_blank" rel="noopener" aria-label="X">
						<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M9.52 6.77L15.48 0h-1.41L8.89 5.88 4.76 0H0l6.25 9.1L0 16h1.41l5.46-6.35L11.24 16H16L9.52 6.77zM7.59 8.93l-.63-.9L1.92 1.04h2.17l4.07 5.82.63.9 5.28 7.56h-2.17L7.59 8.93z"/></svg>
					</a>
					<a href="https://linkedin.com/in/iammukeshm" target="_blank" rel="noopener" aria-label="LinkedIn">
