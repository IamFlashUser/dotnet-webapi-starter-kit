---
interface Props {
	type?: 'note' | 'tip' | 'warning' | 'danger';
	title?: string;
}

const { type = 'note', title } = Astro.props;

const config = {
	note: { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>', defaultTitle: 'Note' },
	tip: { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>', defaultTitle: 'Tip' },
	warning: { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/></svg>', defaultTitle: 'Warning' },
	danger: { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>', defaultTitle: 'Danger' },
};

const { icon, defaultTitle } = config[type];
const displayTitle = title || defaultTitle;
---

<div class:list={['aside', `aside-${type}`]}>
	<div class="aside-header">
		<span class="aside-icon" set:html={icon} />
		<span class="aside-title">{displayTitle}</span>
	</div>
	<div class="aside-content">
		<slot />
	</div>
</div>

<style>
	.aside {
		border-radius: 8px;
		border-left: 3px solid;
		padding: 0.75rem 1rem;
		margin: 1rem 0;
		font-size: 0.88rem;
	}

	.aside-header {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 0.35rem;
		font-weight: 500;
		font-size: 0.82rem;
	}

	.aside-icon {
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.aside-content {
		color: var(--text-dim);
		font-size: 0.85rem;
		line-height: 1.65;
	}
	.aside-content :global(p) {
		margin: 0.25rem 0;
	}
	.aside-content :global(a) {
		color: inherit;
		text-decoration: underline;
	}

	/* Note — blue */
	.aside-note {
		border-color: #3b82f6;
		background: rgba(59, 130, 246, 0.05);
	}
	.aside-note .aside-header { color: #3b82f6; }
	:global(:root[data-theme="dark"]) .aside-note {
		background: rgba(59, 130, 246, 0.06);
	}

	/* Tip — green */
	.aside-tip {
		border-color: #16a34a;
		background: rgba(22, 163, 74, 0.04);
	}
	.aside-tip .aside-header { color: #16a34a; }
	:global(:root[data-theme="dark"]) .aside-tip {
		border-color: #4ade80;
		background: rgba(74, 222, 128, 0.06);
	}
	:global(:root[data-theme="dark"]) .aside-tip .aside-header { color: #4ade80; }

	/* Warning — amber */
	.aside-warning {
		border-color: #d97706;
		background: rgba(217, 119, 6, 0.04);
	}
	.aside-warning .aside-header { color: #d97706; }
	:global(:root[data-theme="dark"]) .aside-warning {
		border-color: #fbbf24;
		background: rgba(251, 191, 36, 0.06);
	}
	:global(:root[data-theme="dark"]) .aside-warning .aside-header { color: #fbbf24; }

	/* Danger — red */
	.aside-danger {
		border-color: #dc2626;
		background: rgba(220, 38, 38, 0.04);
	}
	.aside-danger .aside-header { color: #dc2626; }
	:global(:root[data-theme="dark"]) .aside-danger {
		border-color: #f87171;
		background: rgba(248, 113, 113, 0.06);
	}
	:global(:root[data-theme="dark"]) .aside-danger .aside-header { color: #f87171; }
</style>
