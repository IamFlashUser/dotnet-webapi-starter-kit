---
interface Props {
	labels: string[];
}

const { labels } = Astro.props;
const id = `tabs-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="tabs" data-tabs-id={id}>
	<div class="tabs-header" role="tablist">
		{labels.map((label, i) => (
			<button
				role="tab"
				class:list={['tab-btn', { active: i === 0 }]}
				data-tab-index={i}
				aria-selected={i === 0 ? 'true' : 'false'}
			>
				{label}
			</button>
		))}
	</div>
	<div class="tabs-content">
		<slot />
	</div>
</div>

<script>
	document.querySelectorAll('[data-tabs-id]').forEach((tabs) => {
		const btns = tabs.querySelectorAll('[data-tab-index]');
		const panels = tabs.querySelectorAll('.tab-panel');

		btns.forEach((btn) => {
			btn.addEventListener('click', () => {
				const idx = Number(btn.getAttribute('data-tab-index'));
				btns.forEach((b, i) => {
					b.classList.toggle('active', i === idx);
					b.setAttribute('aria-selected', String(i === idx));
				});
				panels.forEach((p, i) => {
					(p as HTMLElement).style.display = i === idx ? '' : 'none';
				});
			});
		});

		// Init: hide all panels except first
		panels.forEach((p, i) => {
			(p as HTMLElement).style.display = i === 0 ? '' : 'none';
		});
	});
</script>

<style>
	.tabs {
		margin: 1rem 0;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	.tabs-header {
		display: flex;
		border-bottom: 1px solid var(--border);
		background: var(--bg-surface, #f5f5f7);
	}
	:global(:root[data-theme="dark"]) .tabs-header {
		background: var(--bg-surface, #111116);
	}
	.tab-btn {
		flex: 1;
		padding: 0.5rem 0.75rem;
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 500;
		color: var(--text-dim);
		background: none;
		border: none;
		border-bottom: 2px solid transparent;
		cursor: pointer;
		transition: color 0.12s, border-color 0.12s;
	}
	.tab-btn:hover { color: var(--text); }
	.tab-btn.active {
		color: var(--brand);
		border-bottom-color: var(--brand);
	}
	.tabs-content {
		padding: 0.85rem 1rem;
	}
	.tabs-content :global(p) {
		margin: 0.35rem 0;
		font-size: 0.88rem;
	}
</style>
