---
import { sidebar } from '../config/docs.config';

interface Props {
	currentSlug: string;
	title: string;
}

const { currentSlug, title } = Astro.props;

// Find which group this page belongs to
const group = sidebar.find((g) => g.items.some((item) => item.slug === currentSlug));
const groupLabel = group?.label || '';
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
	<a href="/">Home</a>
	<span class="bc-sep">/</span>
	<a href="/docs/introduction/">Docs</a>
	{groupLabel && (
		<>
			<span class="bc-sep">/</span>
			<span class="bc-group">{groupLabel}</span>
		</>
	)}
	<span class="bc-sep">/</span>
	<span class="bc-current">{title}</span>
</nav>

<style>
	.breadcrumbs {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.75rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.breadcrumbs a {
		color: var(--text-faint);
		text-decoration: none;
		transition: color 0.12s;
	}
	.breadcrumbs a:hover {
		color: var(--brand);
	}
	.bc-sep {
		color: var(--text-faint);
		opacity: 0.5;
	}
	.bc-group {
		color: var(--text-faint);
	}
	.bc-current {
		color: var(--text-dim);
		font-weight: 500;
	}
</style>
