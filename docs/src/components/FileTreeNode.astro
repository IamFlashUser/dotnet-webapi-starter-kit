---
interface FileItem {
	name: string;
	type?: 'folder' | 'file';
	desc?: string;
	children?: FileItem[];
}

interface Props {
	item: FileItem;
	depth: number;
}

const { item, depth } = Astro.props;
const isFolder = item.type === 'folder' || !!item.children;

// Self-import for recursion
const FileTreeNode = Astro.self;
---

<div class="ftn">
	<div class="ftn-row" style={`padding-left: calc(0.75rem + ${depth} * 1.1rem)`}>
		{isFolder ? (
			<svg class="ftn-ic ftn-ic-folder" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20h16a2 2 0 002-2V8a2 2 0 00-2-2h-7.93a2 2 0 01-1.66-.9l-.82-1.2A2 2 0 007.93 3H4a2 2 0 00-2 2v13a2 2 0 002 2z"/></svg>
		) : (
			<svg class="ftn-ic ftn-ic-file" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/></svg>
		)}
		<span class:list={['ftn-name', { 'ftn-folder': isFolder }]}>{item.name}</span>
		{item.desc && <span class="ftn-desc">{item.desc}</span>}
	</div>
	{item.children && item.children.map((child) => (
		<FileTreeNode item={child} depth={depth + 1} />
	))}
</div>

<style>
	.ftn-row {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding-top: 0.18rem;
		padding-bottom: 0.18rem;
		padding-right: 0.75rem;
		transition: background 0.08s;
	}
	.ftn-row:hover {
		background: rgba(128,128,128,0.04);
	}

	.ftn-ic { flex-shrink: 0; }
	.ftn-ic-folder { color: var(--brand); }
	.ftn-ic-file { color: var(--text-faint); opacity: 0.55; }

	.ftn-name { color: var(--text-dim); }
	.ftn-folder { color: var(--text); font-weight: 500; }

	.ftn-desc {
		color: var(--text-faint);
		font-size: 0.7rem;
		margin-left: 0.2rem;
		opacity: 0.6;
	}
	.ftn-desc::before { content: '— '; }
</style>
