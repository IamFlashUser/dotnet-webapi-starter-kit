---
interface FileItem {
	name: string;
	type?: 'folder' | 'file';
	desc?: string;
	children?: FileItem[];
}

interface Props {
	item: FileItem;
	depth: number;
	isLast?: boolean;
}

const { item, depth, isLast = false } = Astro.props;
const isFolder = item.type === 'folder' || !!item.children;
const FileTreeNode = Astro.self;

const guideLeft = `calc(0.85rem + ${depth} * 1.15rem + 0.35rem + 7px)`;
const connectorLeft = `calc(0.85rem + ${(depth - 1)} * 1.15rem + 0.35rem + 7px)`;
---

<div class:list={['ftn', { 'ftn-nested': depth > 0, 'ftn-last': isLast }]}>
	{depth > 0 && (
		<span
			class:list={['ftn-elbow', { 'ftn-elbow-last': isLast }]}
			style={`left: ${connectorLeft}`}
		/>
	)}
	<div class="ftn-row" style={`padding-left: calc(0.85rem + ${depth} * 1.15rem)`}>
		{isFolder ? (
			<svg class="ftn-ic ftn-ic-folder" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
		) : (
			<svg class="ftn-ic ftn-ic-file" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
		)}
		<span class:list={['ftn-name', { 'ftn-folder': isFolder }]}>{item.name}</span>
		{item.desc && <span class="ftn-desc">{item.desc}</span>}
	</div>
	{item.children && (
		<div class="ftn-children" style={`--guide-left: ${guideLeft}`}>
			{item.children.map((child, i) => (
				<FileTreeNode item={child} depth={depth + 1} isLast={i === item.children!.length - 1} />
			))}
		</div>
	)}
</div>

<style>
	.ftn {
		position: relative;
	}

	.ftn-row {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding-top: 0.22rem;
		padding-bottom: 0.22rem;
		padding-right: 0.85rem;
		border-radius: 4px;
		margin: 0 0.35rem;
	}
	.ftn-row:hover {
		background: rgba(128,128,128,0.05);
	}

	/*
	 * Elbow connector — an L-shaped line with a rounded corner.
	 * For non-last children: ├─  (vertical runs full height)
	 * For last child:        └─  (vertical stops at center)
	 */
	.ftn-elbow {
		position: absolute;
		top: 0;
		bottom: 0;
		width: calc(1.15rem - 7px + 0.4rem);
		border-left: 1px solid var(--tree-line, rgba(128,128,128,0.18));
		pointer-events: none;
	}
	.ftn-elbow::after {
		content: '';
		position: absolute;
		left: -1px;
		top: calc(0.22rem + 7px);
		width: calc(1.15rem - 7px);
		height: 0;
		border-bottom: 1px solid var(--tree-line, rgba(128,128,128,0.18));
		border-left: 1px solid var(--tree-line, rgba(128,128,128,0.18));
		border-bottom-left-radius: 6px;
		box-sizing: border-box;
	}

	/* Last child: vertical stops at the horizontal branch */
	.ftn-elbow-last {
		bottom: auto;
		height: calc(0.22rem + 7px + 1px);
	}

	/* Vertical guide line for children group */
	.ftn-children {
		position: relative;
	}

	.ftn-ic { flex-shrink: 0; opacity: 0.55; }
	.ftn-ic-folder { color: var(--brand); opacity: 0.7; }
	.ftn-ic-file { color: var(--text-faint); }

	.ftn-name {
		color: var(--text-dim);
		font-weight: 400;
		font-size: 0.82rem;
		letter-spacing: -0.005em;
	}
	.ftn-folder {
		color: var(--text);
		font-weight: 400;
	}

	.ftn-desc {
		color: var(--text-faint);
		font-size: 0.74rem;
		margin-left: 0.15rem;
		opacity: 0.55;
		font-style: italic;
	}
	.ftn-desc::before { content: '— '; font-style: normal; }
</style>
