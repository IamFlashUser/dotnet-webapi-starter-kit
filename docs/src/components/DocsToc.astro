---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
	<nav class="docs-toc" aria-label="Table of contents">
		<div class="toc-header">
			<span class="toc-title">On this page</span>
			<span class="toc-count">{tocHeadings.length}</span>
		</div>
		<div class="toc-track">
			<div class="toc-indicator" id="toc-indicator" />
			<ul class="toc-list" id="toc-list">
				{tocHeadings.map((h) => (
					<li>
						<a
							href={`#${h.slug}`}
							class:list={[`depth-${h.depth}`]}
						>
							{h.text}
						</a>
					</li>
				))}
			</ul>
		</div>
	</nav>
)}

<script>
	const tocList = document.getElementById('toc-list');
	const indicator = document.getElementById('toc-indicator');
	if (tocList && indicator) {
		const tocLinks = tocList.querySelectorAll('a');
		const headings = Array.from(tocLinks).map((link) => {
			const id = link.getAttribute('href')?.slice(1);
			return id ? document.getElementById(id) : null;
		}).filter(Boolean) as HTMLElement[];

		// Smooth scroll on click
		tocLinks.forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const id = link.getAttribute('href')?.slice(1);
				const target = id ? document.getElementById(id) : null;
				if (target) {
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
					history.replaceState(null, '', `#${id}`);
				}
			});
		});

		// Move the indicator bar to the active link
		function moveIndicator(activeLink: Element) {
			const listRect = tocList!.getBoundingClientRect();
			const linkRect = activeLink.getBoundingClientRect();
			const top = linkRect.top - listRect.top + tocList!.scrollTop;
			indicator!.style.transform = `translateY(${top}px)`;
			indicator!.style.height = `${linkRect.height}px`;
		}

		// Highlight active on scroll
		function updateActive() {
			let current = 0;
			for (let i = 0; i < headings.length; i++) {
				if (headings[i].getBoundingClientRect().top <= 100) {
					current = i;
				}
			}
			tocLinks.forEach((link, i) => {
				const isActive = i === current;
				link.classList.toggle('active', isActive);
				if (isActive) moveIndicator(link);
			});
		}

		// Position immediately - no fade-in delay
		updateActive();
		window.addEventListener('scroll', updateActive, { passive: true });
	}
</script>
