---
import { Image } from 'astro:assets';
import logo from '../assets/icon.png';
---
<header class="hd" id="hd">
	<div class="hd-in">
		<a href="/" class="hd-brand">
			<Image src={logo} alt="fullstackhero" width={108} height={108} quality={100} densities={[1, 2, 3]} class="hd-logo" loading="eager" decoding="sync" fetchpriority="high" />
			<span class="hd-wordmark">fullstack<strong>hero</strong></span>
		</a>

		<button class="hd-search" id="hd-search">
			<svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="6.5" cy="6.5" r="4.5"/><path d="M10 10l4.5 4.5"/></svg>
			<span>Search</span>
			<kbd>/</kbd>
		</button>

		<nav class="hd-nav">
			<a href="/docs/introduction/">Docs</a>
			<a href="/docs/architecture/">Architecture</a>
			<a href="/docs/modules/identity/">Modules</a>
			<a href="/docs/adding-a-feature/">Guides</a>
		</nav>

		<div class="hd-end">
			<div class="hd-sep"></div>
			<a href="https://github.com/fullstackhero/dotnet-starter-kit" target="_blank" rel="noopener" class="hd-icon" aria-label="GitHub">
