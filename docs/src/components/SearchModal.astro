<!-- Search modal - powered by Pagefind -->
<dialog class="search-modal" id="search-modal">
	<div class="sm-inner">
		<div class="sm-header">
			<div class="sm-input-wrap">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
				<input type="text" id="search-input" placeholder="Search docs..." autocomplete="off" autofocus />
				<kbd>Esc</kbd>
			</div>
		</div>
		<div class="sm-body">
			<div class="sm-results" id="search-results"></div>
			<div class="sm-empty-state" id="search-empty" style="display:none;">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6"/></svg>
				<p class="sm-empty-title">Search unavailable in dev mode</p>
				<p class="sm-empty-hint">Run <code>npm run build</code> first</p>
			</div>
			<div class="sm-no-results" id="search-no-results" style="display:none;">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
				<p class="sm-empty-title">No results found</p>
				<p class="sm-empty-hint">Try a different search term</p>
			</div>
		</div>
		<div class="sm-footer">
			<span>Search by Pagefind</span>
		</div>
	</div>
</dialog>

<script>
	const modal = document.getElementById('search-modal') as HTMLDialogElement;
	const input = document.getElementById('search-input') as HTMLInputElement;
	const results = document.getElementById('search-results')!;
	const emptyState = document.getElementById('search-empty')!;
	const noResults = document.getElementById('search-no-results')!;
	let pagefind: any = null;

	function hideAllStates() {
		emptyState.style.display = 'none';
		noResults.style.display = 'none';
		results.innerHTML = '';
	}

	// Load pagefind lazily on first open
	async function loadPagefind() {
		if (pagefind) return;
		try {
			const mod = await (new Function('return import("/pagefind/pagefind.js")'))();
			pagefind = mod;
			await pagefind.init();
		} catch {
			emptyState.style.display = '';
		}
	}

	// Open modal
	function openSearch() {
		modal.showModal();
		input.focus();
		loadPagefind();
	}

	// Close modal
	function closeSearch() {
		modal.close();
		input.value = '';
		hideAllStates();
	}

	// Search
	let debounce: ReturnType<typeof setTimeout>;
	input?.addEventListener('input', () => {
		clearTimeout(debounce);
		debounce = setTimeout(async () => {
			const query = input.value.trim();
			if (!query || !pagefind) {
				hideAllStates();
				return;
			}
			const search = await pagefind.search(query);
			const items = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

			hideAllStates();
			if (items.length === 0) {
				noResults.style.display = '';
				return;
			}

			results.innerHTML = items.map((item: any) => `
				<a href="${item.url}" class="sm-result" onclick="document.getElementById('search-modal').close()">
					<span class="sm-result-title">${item.meta.title || item.url}</span>
					<span class="sm-result-excerpt">${item.excerpt}</span>
				</a>
			`).join('');
		}, 150);
	});

	// Close on Esc or backdrop click
	modal?.addEventListener('click', (e) => {
		if (e.target === modal) closeSearch();
	});

	// Global keyboard shortcuts
	document.addEventListener('keydown', (e) => {
		if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === '/')) {
			e.preventDefault();
			openSearch();
		}
		if (e.key === '/' && !['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName || '')) {
			e.preventDefault();
			openSearch();
		}
	});

	// Expose globally for the nav search button
	(window as any).__openSearch = openSearch;
</script>

<style>
	.search-modal {
		border: none;
		background: none;
		padding: 0;
		max-width: 100%;
		max-height: 100%;
		width: 100%;
		height: 100%;
		overflow: hidden;
	}
	.search-modal::backdrop {
		background: rgba(0,0,0,0.4);
		backdrop-filter: blur(4px);
	}
	:root[data-theme="dark"] .search-modal::backdrop {
		background: rgba(0,0,0,0.6);
	}

	.sm-inner {
		width: min(90vw, 36rem);
		margin: 12vh auto 0;
		background: var(--bg-card, #fff);
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 16px 48px rgba(0,0,0,0.12);
		font-size: 16px;
	}
	:root[data-theme="dark"] .sm-inner {
		box-shadow: 0 16px 48px rgba(0,0,0,0.4);
	}

	.sm-header {
		padding: 0.75rem;
		border-bottom: 1px solid var(--border);
	}
	.sm-input-wrap {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.65rem;
		border-radius: 8px;
		background: var(--bg-surface, #f5f5f7);
	}
	:root[data-theme="dark"] .sm-input-wrap {
		background: var(--bg-surface, #111116);
	}
	.sm-input-wrap svg {
		color: var(--text-faint);
		flex-shrink: 0;
	}
	.sm-input-wrap input {
		flex: 1;
		border: none;
		background: none;
		outline: none;
		font-family: var(--sans);
		font-size: 0.9rem;
		color: var(--text);
	}
	.sm-input-wrap input::placeholder {
		color: var(--text-faint);
	}
	.sm-input-wrap kbd {
		font-family: var(--sans);
		font-size: 0.6rem;
		font-weight: 500;
		padding: 0.12rem 0.35rem;
		border-radius: 4px;
		background: var(--bg-card, #fff);
		border: 1px solid var(--border);
		color: var(--text-faint);
	}

	.sm-body {
		max-height: 50vh;
		overflow-y: auto;
	}

	/* Search results */
	.sm-results:empty { display: none; }

	/* Empty / no-results states */
	.sm-empty-state,
	.sm-no-results {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
		padding: 2rem 1.5rem;
		text-align: center;
	}
	.sm-empty-state svg,
	.sm-no-results svg {
		opacity: 0.2;
		margin-bottom: 0.25rem;
	}
	.sm-empty-title {
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--text-dim);
		margin: 0;
	}
	.sm-empty-hint {
		font-size: 0.72rem;
		color: var(--text-faint);
		margin: 0;
	}
	.sm-empty-hint code {
		font-family: var(--mono);
		font-size: 0.65rem;
		background: var(--bg-surface);
		padding: 0.12em 0.4em;
		border-radius: 4px;
		border: 1px solid var(--border);
	}

	.sm-footer {
		padding: 0.4rem 1rem;
		border-top: 1px solid var(--border);
		font-size: 0.6rem;
		color: var(--text-faint);
		text-align: center;
		letter-spacing: 0.02em;
	}
</style>

<!-- Results are injected via innerHTML - need global styles -->
<style is:global>
	.sm-result {
		display: block;
		padding: 0.55rem 1rem;
		border-bottom: 1px solid var(--border);
		text-decoration: none;
		transition: background 0.1s;
	}
	.sm-result:hover {
		background: rgba(128,128,128,0.04);
	}
	.sm-result:last-child {
		border-bottom: none;
	}
	.sm-result-title {
		display: block;
		font-size: 0.82rem;
		font-weight: 500;
		color: var(--text);
		margin-bottom: 0.1rem;
	}
	.sm-result-excerpt {
		display: block;
		font-size: 0.72rem;
		color: var(--text-dim);
		line-height: 1.5;
	}
	.sm-result-excerpt mark {
		background: rgba(22,163,74,0.15);
		color: var(--brand);
		border-radius: 2px;
		padding: 0 0.1em;
	}
	:root[data-theme="dark"] .sm-result-excerpt mark {
		background: rgba(74,222,128,0.12);
	}
</style>
