---
import FileTreeNode from './FileTreeNode.astro';

interface FileItem {
	name: string;
	type?: 'folder' | 'file';
	desc?: string;
	children?: FileItem[];
}

interface Props {
	items: FileItem[];
}

const { items } = Astro.props;
---

<div class="ftree">
	{items.map((item) => <FileTreeNode item={item} depth={0} />)}
</div>

<style>
	.ftree {
		margin: 1rem 0;
		padding: 0.45rem 0;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--bg-surface, #f8f8fa);
		font-family: var(--sans);
		font-size: 0.8rem;
		width: fit-content;
		min-width: min(100%, 22rem);
		max-width: 100%;
		overflow: hidden;
		line-height: 1.4;
	}
	:global(:root[data-theme="dark"]) .ftree {
		background: var(--bg-surface, #111116);
	}
</style>
