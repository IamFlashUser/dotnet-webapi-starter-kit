---
interface Props {
	variant?: 'default' | 'success' | 'warning' | 'danger' | 'outline';
	size?: 'sm' | 'md';
}

const { variant = 'default', size = 'sm' } = Astro.props;
---

<span class:list={['badge', `badge-${variant}`, `badge-${size}`]}><slot /></span>

<style>
	.badge {
		display: inline-flex;
		align-items: center;
		font-weight: 500;
		border-radius: 999px;
		white-space: nowrap;
		letter-spacing: 0.01em;
	}
	.badge-sm { font-size: 0.68rem; padding: 0.12rem 0.5rem; }
	.badge-md { font-size: 0.78rem; padding: 0.18rem 0.65rem; }

	.badge-default { background: rgba(22,163,74,0.08); color: #16a34a; }
	:global(:root[data-theme="dark"]) .badge-default { background: rgba(74,222,128,0.1); color: #4ade80; }

	.badge-success { background: rgba(22,163,74,0.08); color: #16a34a; }
	:global(:root[data-theme="dark"]) .badge-success { background: rgba(74,222,128,0.1); color: #4ade80; }

	.badge-warning { background: rgba(217,119,6,0.08); color: #d97706; }
	:global(:root[data-theme="dark"]) .badge-warning { background: rgba(251,191,36,0.1); color: #fbbf24; }

	.badge-danger { background: rgba(220,38,38,0.08); color: #dc2626; }
	:global(:root[data-theme="dark"]) .badge-danger { background: rgba(248,113,113,0.1); color: #f87171; }

	.badge-outline { background: none; border: 1px solid var(--border); color: var(--text-dim); }
</style>
