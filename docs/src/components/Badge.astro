---
interface Props {
	variant?: 'default' | 'success' | 'warning' | 'danger' | 'outline';
	size?: 'sm' | 'md';
}

const { variant = 'default', size = 'sm' } = Astro.props;
---

<span class:list={['badge', `badge-${variant}`, `badge-${size}`]}><slot /></span>

<style>
	.badge {
		display: inline-flex;
		align-items: center;
		font-weight: 500;
		border-radius: 999px;
		white-space: nowrap;
		letter-spacing: 0.01em;
		border: 1px solid transparent;
	}
	.badge-sm { font-size: 0.68rem; padding: 0.2rem 0.6rem; }
	.badge-md { font-size: 0.78rem; padding: 0.25rem 0.75rem; }

	.badge-default { background: rgba(22,163,74,0.08); color: #16a34a; border-color: rgba(22,163,74,0.2); }
	:global(:root[data-theme="dark"]) .badge-default { background: rgba(74,222,128,0.1); color: #4ade80; border-color: rgba(74,222,128,0.2); }

	.badge-success { background: rgba(22,163,74,0.08); color: #16a34a; border-color: rgba(22,163,74,0.2); }
	:global(:root[data-theme="dark"]) .badge-success { background: rgba(74,222,128,0.1); color: #4ade80; border-color: rgba(74,222,128,0.2); }

	.badge-warning { background: rgba(217,119,6,0.08); color: #d97706; border-color: rgba(217,119,6,0.2); }
	:global(:root[data-theme="dark"]) .badge-warning { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.2); }

	.badge-danger { background: rgba(220,38,38,0.08); color: #dc2626; border-color: rgba(220,38,38,0.2); }
	:global(:root[data-theme="dark"]) .badge-danger { background: rgba(248,113,113,0.1); color: #f87171; border-color: rgba(248,113,113,0.2); }

	.badge-outline { background: none; border: 1px solid var(--border); color: var(--text-dim); }
</style>
