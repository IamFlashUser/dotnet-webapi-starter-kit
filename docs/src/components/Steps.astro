---
// Steps component — wraps numbered steps
---

<div class="steps"><slot /></div>

<style>
	.steps {
		counter-reset: step;
		position: relative;
		margin: 1.25rem 0;
		padding-left: 3rem;
	}

	/* Continuous vertical line */
	.steps::before {
		content: '';
		position: absolute;
		left: 0.9rem;
		top: 0;
		bottom: 0;
		width: 1px;
		background: linear-gradient(
			to bottom,
			transparent 0,
			var(--border) 1.5rem,
			var(--border) calc(100% - 1.5rem),
			transparent 100%
		);
	}

	/* All direct children */
	.steps :global(> *) {
		position: relative;
		padding-bottom: 0.5rem;
	}

	.steps :global(> *:last-child) {
		padding-bottom: 0;
	}

	/* Headings */
	.steps :global(> h3),
	.steps :global(> h4) {
		counter-increment: step;
		padding-top: 1.5rem;
		padding-bottom: 0.35rem;
	}

	.steps :global(> h3:first-child),
	.steps :global(> h4:first-child) {
		padding-top: 0;
	}

	/* Step number */
	.steps :global(> h3::before),
	.steps :global(> h4::before) {
		content: counter(step);
		position: absolute;
		left: -3rem;
		top: 1.5rem;
		width: 1.8rem;
		height: 1.8rem;
		display: grid;
		place-items: center;
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--brand);
		background: var(--bg-card, var(--bg));
		border: 1.5px solid var(--brand);
		border-radius: 8px;
		line-height: 1;
		box-shadow: 0 0 0 3px var(--bg), 0 1px 3px rgba(0,0,0,0.04);
		z-index: 1;
	}

	.steps :global(> h3:first-child::before),
	.steps :global(> h4:first-child::before) {
		top: 0;
	}

	@media (max-width: 768px) {
		.steps {
			padding-left: 2.5rem;
		}
		.steps::before {
			left: 0.75rem;
		}
		.steps :global(> h3::before),
		.steps :global(> h4::before) {
			left: -2.5rem;
			width: 1.5rem;
			height: 1.5rem;
			font-size: 0.62rem;
			border-radius: 6px;
			box-shadow: 0 0 0 3px var(--bg);
		}
	}
</style>
