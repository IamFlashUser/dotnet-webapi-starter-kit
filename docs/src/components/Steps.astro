---
// Steps component — wraps numbered steps
---

<div class="steps"><slot /></div>

<style>
	.steps {
		counter-reset: step;
		padding-left: 1.75rem;
		border-left: 2px solid var(--border);
		margin: 1rem 0;
	}
	.steps :global(> *) {
		position: relative;
		padding-bottom: 1.25rem;
	}
	.steps :global(> *:last-child) {
		padding-bottom: 0;
	}
	.steps :global(> h3),
	.steps :global(> h4) {
		counter-increment: step;
	}
	.steps :global(> h3::before),
	.steps :global(> h4::before) {
		content: counter(step);
		position: absolute;
		left: -2.55rem;
		top: 0;
		width: 1.6rem;
		height: 1.6rem;
		display: grid;
		place-items: center;
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--brand);
		background: var(--bg);
		border: 2px solid var(--brand);
		border-radius: 50%;
		line-height: 1;
	}

	@media (max-width: 768px) {
		.steps {
			padding-left: 1.4rem;
		}
		.steps :global(> h3::before),
		.steps :global(> h4::before) {
			left: -2.15rem;
			width: 1.4rem;
			height: 1.4rem;
			font-size: 0.65rem;
		}
	}
</style>
