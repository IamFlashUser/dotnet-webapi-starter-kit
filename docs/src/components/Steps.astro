---
// Steps component — wraps numbered steps
---

<div class="steps"><slot /></div>

<style>
	.steps {
		counter-reset: step;
		position: relative;
		margin: 1.25rem 0;
		padding-left: 2.75rem;
	}

	/* Continuous vertical line through all steps */
	.steps::before {
		content: '';
		position: absolute;
		left: 0.8rem;
		top: 0.85rem;
		bottom: 0.85rem;
		width: 2px;
		background: var(--border);
		border-radius: 1px;
	}

	/* All direct children */
	.steps :global(> *) {
		position: relative;
		padding-bottom: 0.5rem;
	}

	.steps :global(> *:last-child) {
		padding-bottom: 0;
	}

	/* Headings: increment counter, add top spacing */
	.steps :global(> h3),
	.steps :global(> h4) {
		counter-increment: step;
		padding-top: 1.25rem;
		padding-bottom: 0.35rem;
	}

	.steps :global(> h3:first-child),
	.steps :global(> h4:first-child) {
		padding-top: 0;
	}

	/* Step number circle */
	.steps :global(> h3::before),
	.steps :global(> h4::before) {
		content: counter(step);
		position: absolute;
		left: -2.75rem;
		top: 1.25rem;
		width: 1.6rem;
		height: 1.6rem;
		display: grid;
		place-items: center;
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--bg);
		background: var(--brand);
		border-radius: 50%;
		line-height: 1;
		box-shadow: 0 0 0 4px var(--bg);
		z-index: 1;
	}

	.steps :global(> h3:first-child::before),
	.steps :global(> h4:first-child::before) {
		top: 0;
	}

	@media (max-width: 768px) {
		.steps {
			padding-left: 2.25rem;
		}
		.steps::before {
			left: 0.65rem;
		}
		.steps :global(> h3::before),
		.steps :global(> h4::before) {
			left: -2.25rem;
			width: 1.3rem;
			height: 1.3rem;
			font-size: 0.6rem;
			box-shadow: 0 0 0 3px var(--bg);
		}
	}
</style>
