---
// System fonts — no external font loading, zero FOUT

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
const canonicalURL = 'https://fullstackhero.net/';
const ogImage = 'https://fullstackhero.net/og-image.png';

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- Canonical -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="fullstackhero" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@iammukeshm" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Additional SEO -->
		<meta name="author" content="Mukesh Murugan" />
		<meta name="robots" content="index, follow" />
		<meta name="keywords" content=".NET starter kit, modular monolith, vertical slice architecture, multitenancy, CQRS, .NET 10, ASP.NET Core, fullstackhero, SaaS boilerplate" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Theme: apply before first paint to prevent FOUC -->
		<script is:inline>
			(function(){
				var t = localStorage.getItem('fsh-theme');
				if (t === 'dark') document.documentElement.setAttribute('data-theme','dark');
			})();
		</script>

		<!-- Structured Data: Organization -->
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "fullstackhero",
			"url": "https://fullstackhero.net",
			"logo": {
				"@type": "ImageObject",
				"url": "https://fullstackhero.net/favicon.svg",
				"width": 512,
				"height": 512
			},
			"foundingDate": "2020-10-06",
			"description": "Open-source .NET 10 modular monolith starter kit with multitenancy, identity, CQRS, and vertical slice architecture.",
			"founder": {
				"@type": "Person",
				"name": "Mukesh Murugan",
				"url": "https://codewithmukesh.com",
				"jobTitle": "Software Engineer",
				"sameAs": [
					"https://twitter.com/iammukeshm",
					"https://www.linkedin.com/in/iammukeshm/",
					"https://github.com/iammukeshm",
					"https://youtube.com/@codewithmukesh"
				]
			},
			"sameAs": [
				"https://github.com/fullstackhero",
				"https://github.com/fullstackhero/dotnet-starter-kit",
				"https://twitter.com/iammukeshm",
				"https://www.linkedin.com/in/iammukeshm/",
				"https://youtube.com/@codewithmukesh",
				"https://codewithmukesh.com",
				"https://www.nuget.org/profiles/fullstackhero"
			]
		})}</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	/* ── Light mode (default) ──── */
	:root {
		--bg: #fafafa;
		--bg-card: #ffffff;
		--bg-surface: #f0f0f3;
		--border: rgba(0,0,0,0.07);
		--border-bright: rgba(0,0,0,0.13);
		--text: #111113;
		--text-dim: #4b4b5e;
		--text-faint: #8b8b9e;
		--brand: #16a34a;
		--brand-dim: #15803d;
		--brand-glow: rgba(22,163,74,0.10);
		--brand-glow-strong: rgba(22,163,74,0.18);
		--code-bg: #f3f3f6;
		--nav-bg: rgba(250,250,250,0.85);
		--term-bg: #1a1a1e;
		--term-text: #e8e8ed;
		--term-dim: #8b8b9e;
		--term-faint: #55556a;
		--mono: ui-monospace, 'SF Mono', 'Cascadia Code', 'Segoe UI Mono', Menlo, Consolas, 'Liberation Mono', monospace;
		--sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif;
		color-scheme: light;
	}

	/* ── Dark mode ──────────────── */
	:root[data-theme="dark"] {
		--bg: #0a0a0c;
		--bg-card: #111116;
		--bg-surface: #16161c;
		--border: rgba(255,255,255,0.08);
		--border-bright: rgba(255,255,255,0.14);
		--text: #ededf0;
		--text-dim: #a8a8b8;
		--text-faint: #6e6e82;
		--brand: #4ade80;
		--brand-dim: #22c55e;
		--brand-glow: rgba(74,222,128,0.12);
		--brand-glow-strong: rgba(74,222,128,0.22);
		--code-bg: #16161c;
		--nav-bg: rgba(10,10,12,0.85);
		--term-bg: rgba(10,10,12,0.9);
		--term-text: #ededf0;
		--term-dim: #a8a8b8;
		--term-faint: #6e6e82;
		color-scheme: dark;
	}

	html {
		font-family: var(--sans);
		font-feature-settings: 'liga' 1, 'calt' 1;
		font-size: 125%;
		background: var(--bg);
		color: var(--text);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		scroll-behavior: smooth;
		transition: background .2s, color .2s;
	}

	@media (max-width: 768px) {
		html { font-size: 100%; }
	}

	body { min-height: 100vh; overflow-x: hidden; display: flex; flex-direction: column; }
	body > footer, body .ft { margin-top: auto; }
	a { color: inherit; text-decoration: none; }
	::selection { background: rgba(22,163,74,0.15); }
	:root[data-theme="dark"] ::selection { background: rgba(74,222,128,0.2); }
</style>
