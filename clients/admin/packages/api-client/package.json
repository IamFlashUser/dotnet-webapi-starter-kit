{
  "name": "@fsh/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./endpoints/*": {
      "types": "./src/endpoints/*.ts",
      "default": "./src/endpoints/*.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
